      {
        "name": "_Medidas",
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ],
        "lineageTag": "e1045235-e3c8-416c-b155-523e55311d50",
        "measures": [
          {
            "name": "01. Total Faturamento",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "displayFolder": "01. Faturamento\\Totais",
            "expression": [
              "",
              "// Soma total de Faturamento com Desconto",
              "SUMX(",
              "    TB_NotaFiscal,",
              "    TB_NotaFiscal[NFI_ValorTotal] - TB_NotaFiscal[NFI_ValorDesconto] )"
            ],
            "formatString": "\"R$\"\\ #,0.00;-\"R$\"\\ #,0.00;\"R$\"\\ #,0.00",
            "lineageTag": "97ad3d4f-39bb-4b44-9caa-04838c809388"
          },
          {
            "name": "01. Qtd Vendas",
            "displayFolder": "01. Faturamento\\Totais",
            "expression": [
              "",
              "// Mostra a quantidade de notas vendidas",
              "DISTINCTCOUNT( TB_NotaFiscal[NTF_Codigo] )"
            ],
            "formatString": "#,0",
            "lineageTag": "7cd002c3-416f-4da7-8d41-f9f5d8e0c3a4"
          },
          {
            "name": "01. Tickt Medio",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "displayFolder": "01. Faturamento\\Totais",
            "expression": [
              "",
              "// faturamento / quiantidade de notas",
              "DIVIDE( [01. Total Faturamento], [01. Qtd Vendas], 0 )"
            ],
            "lineageTag": "f70eb5b8-2598-4cdb-8e83-5aefcc620fc7"
          },
          {
            "name": "01. Descontos",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "displayFolder": "01. Faturamento\\Totais",
            "expression": [
              "",
              "// Mostra o total de descontos cedidos",
              "SUM( TB_NotaFiscal[NFI_ValorDesconto] )"
            ],
            "lineageTag": "53739b46-8493-4ea4-aeac-1c23f688f604"
          },
          {
            "name": "02. Quantidade/Volume",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "displayFolder": "02. Volume\\Totais",
            "expression": [
              "",
              "// Volume Vendidos",
              "SUM( TB_NotaFiscal[NFI_Quantidade] )"
            ],
            "formatString": "#,0",
            "lineageTag": "17d16c1b-79da-488b-8cda-d41a833ebdc2"
          },
          {
            "name": "01. Fat Ano Anterior",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "displayFolder": "01. Faturamento\\Totais",
            "expression": [
              "",
              "// faturamento do Ano anterior( comparação )",
              "CALCULATE(",
              "    [01. Total Faturamento],",
              "    SAMEPERIODLASTYEAR( 'CALENDARIO DAX'[Date] )",
              ")"
            ],
            "formatString": "\"R$\"\\ #,0.00;-\"R$\"\\ #,0.00;\"R$\"\\ #,0.00",
            "lineageTag": "f6c196e1-595e-447c-88e7-892b24d189f3"
          },
          {
            "name": "01. YTD",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "displayFolder": "01. Faturamento\\YTD",
            "expression": [
              "",
              "// Year to Date",
              "IF(",
              "    ISBLANK( [01. Total Faturamento] ), BLANK() ,",
              "TOTALYTD(",
              "    [01. Total Faturamento],",
              "    'CALENDARIO DAX'[Date] )",
              ")"
            ],
            "formatString": "\"R$\"\\ #,0.00;-\"R$\"\\ #,0.00;\"R$\"\\ #,0.00",
            "lineageTag": "72e13f21-e45d-43de-958d-c8846db6fcea"
          },
          {
            "name": "01. % vs Ano Ant",
            "displayFolder": "01. Faturamento\\%",
            "expression": [
              "",
              "// % versus ano anterior",
              "DIVIDE( [01. Total Faturamento], [01. Fat Ano Anterior], 0 )"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "4028c4ef-83f0-462b-a315-399b5a090145"
          },
          {
            "name": "01. Preco Medio",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "displayFolder": "01. Faturamento\\Totais",
            "expression": [
              "",
              "// Preco medio consite em faturamento / volume",
              "DIVIDE( [01. Total Faturamento], [02. Quantidade/Volume] , 0 )"
            ],
            "formatString": "\"R$\"\\ #,0.00;-\"R$\"\\ #,0.00;\"R$\"\\ #,0.00",
            "lineageTag": "d76bb4bb-aca3-4f8b-b984-42c6f521ca29"
          },
          {
            "name": "02. % vs Ano Ant",
            "displayFolder": "02. Volume\\%",
            "expression": [
              "",
              "// Volume vs Ano anterior",
              "DIVIDE( [02. Quantidade/Volume] , [02. Vol Ano Ant], 0 )"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "1b63a926-2def-46fa-9195-13361091a0ec"
          },
          {
            "name": "02. Vol Ano Ant",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "displayFolder": "02. Volume\\Totais",
            "expression": [
              "",
              "// Volume do Ano anterior",
              "CALCULATE(",
              "    [02. Quantidade/Volume],",
              "    SAMEPERIODLASTYEAR( 'CALENDARIO DAX'[Date] )",
              ")"
            ],
            "lineageTag": "1b30f32e-6f6e-4d2d-b40f-b08502302b0a"
          },
          {
            "name": "Eixo 0",
            "expression": [
              "",
              "// traz o eixo 0 para colocar no grafico o % de Diferença",
              "0"
            ],
            "formatString": "0",
            "lineageTag": "76201000-9881-4ac7-9d6c-d1eef3ef8921"
          },
          {
            "name": "* PeriodoFormatado",
            "displayFolder": "Calendario",
            "expression": [
              "",
              "// Mostra o inicio e final do mes filtrado",
              "VAR DataMin = MIN('CALENDARIO DAX'[Date])",
              "VAR DataMax = MAX('CALENDARIO DAX'[Date])",
              "RETURN ",
              "\"Data: \" & UNICHAR(10) &",
              "FORMAT(DataMin, \"dd mmm yyyy\") &",
              "\" - \" &",
              "FORMAT(DataMax, \"dd mmm yyyy\")"
            ],
            "lineageTag": "7c3e1624-a7e8-4b03-ab50-d7f476692749"
          },
          {
            "name": "* VendaATUAL",
            "displayFolder": "Calendario",
            "expression": [
              "",
              "\"Venda Atual (\" & SELECTEDVALUE( 'CALENDARIO DAX'[Ano-Mes] ) & \" )\""
            ],
            "lineageTag": "89f503ea-caaf-4ae8-a389-e759b7c9f711"
          },
          {
            "name": "* Ultima data Faturamento",
            "displayFolder": "Calendario",
            "expression": [
              "",
              "// mostra qual data teve ultimo fatutamento",
              "FORMAT( MAX( TB_NotaFiscal[NTF_DataEmissao] ), \"dd/mm/yyyy\" )"
            ],
            "lineageTag": "a06e468a-2ecb-4ddf-883a-ddf4813d4957"
          },
          {
            "name": "$ % Tendencia vs Faturamento Ano Ant",
            "expression": [
              "",
              "// Mostra quantos ( % ) esta tendenciando a ficar abaixo do ano anterior",
              "VAR vtend = ",
              "DIVIDE( [01. Tendencia]- [01. Fat Ano Anterior], [01. Fat Ano Anterior], 0 )",
              "VAR _Percent = ",
              "SWITCH(",
              "    TRUE(),",
              "    vtend > 0 , \"⮝\",",
              "    \"⮟\" )",
              "VAR _AB = ",
              "SWITCH(",
              "    TRUE(),",
              "    vtend > 0 , \" Acima\",",
              "    \" Abaixo\" )",
              "RETURN",
              "IF(",
              "    ISBLANK( [01. Total Faturamento] ), BLANK(),",
              "_Percent & FORMAT( vtend, \"Percent\" ) & _AB )"
            ],
            "lineageTag": "7abba8ac-61e1-4345-b532-c35cb6164e3d"
          },
          {
            "name": "01. Tendencia",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "displayFolder": "01. Faturamento\\Totais",
            "expression": [
              "",
              "// Mostra como esta tendenciando a fechar o mes caso continue esse faturamento diario",
              "var vTEND = ",
              "DIVIDE([01. Total Faturamento] ,[DIAS_PERCORRIDOS])",
              "RETURN",
              "vTEND * [TOTAL_DIAS]"
            ],
            "lineageTag": "c5e82727-f80d-4b7d-8279-0c759da00bbb"
          },
          {
            "name": "*Calendario Vendas Faturamento",
            "displayFolder": "Calendario",
            "expression": [
              "",
              "var vDia = SELECTEDVALUE('CALENDARIO DAX'[Dia])",
              "",
              "var vTOTAL_Vendas = ",
              "   FORMAT( [01. Total Faturamento] , \"#,00\" )",
              "RETURN",
              "vDia & UNICHAR(10) & vTOTAL_Vendas"
            ],
            "lineageTag": "3afcb1d1-c048-469b-aec8-1d46e8a31b0c"
          },
          {
            "name": "*Format calendario fundo_fat",
            "displayFolder": "Calendario",
            "expression": [
              "",
              "var vDIASEMANA = SELECTEDVALUE('CALENDARIO DAX'[SemanaDIAnum])",
              "var vCHECK = ",
              "SWITCH(",
              "    TRUE(),",
              "    ISBLANK([01. Total Faturamento]),\"blanck\",",
              "    vDIASEMANA IN {1 , 7}, \"#a8a8a8\",\"#d8d8d8\")",
              "RETURN",
              "vCHECK"
            ],
            "lineageTag": "cf7ac118-55e4-4aa0-86d6-3072e38a992c"
          },
          {
            "name": "*Format Calendario_Fat",
            "displayFolder": "Calendario",
            "expression": [
              "",
              "IF(",
              "    ISBLANK([01. Total Faturamento]),\"#a8a8a8\", \"#333333\"",
              "    )"
            ],
            "lineageTag": "00df6e85-6e1b-4427-b8f7-19b57a636caa"
          },
          {
            "name": "*Format Calendario Subtitulo_fat",
            "displayFolder": "Calendario",
            "expression": [
              "",
              "var vMES_ANO = SELECTEDVALUE('CALENDARIO DAX'[Ano-Mes])",
              "RETURN",
              "",
              "\"Total de Faturado em \" & vMES_ANO & \" é de R$ \" & FORMAT([01. Total Faturamento],\"#,0\") & \" || Média por Dia: R$ \" & FORMAT( [01. Media de Faturamento], \"#,0\" )"
            ],
            "lineageTag": "ecf7467d-fb80-4d2b-829c-786abbae830f"
          },
          {
            "name": "01. YTD Ano Ant",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "displayFolder": "01. Faturamento\\YTD",
            "expression": [
              "",
              "// Retorna o year to date do ano anterior",
              "CALCULATE(",
              "    [01. YTD],",
              "    SAMEPERIODLASTYEAR( 'CALENDARIO DAX'[Date] )",
              ")"
            ],
            "formatString": "\"R$\"\\ #,0.00;-\"R$\"\\ #,0.00;\"R$\"\\ #,0.00",
            "lineageTag": "630ea07c-9b7a-408c-b137-ec7321f1fc2a"
          },
          {
            "name": "01. % YTD vs Ano Ant",
            "displayFolder": "01. Faturamento\\%",
            "expression": [
              "",
              "// Mostra o ( % ) vs o ano anterior ",
              "DIVIDE( [01. YTD] , [01. YTD Ano Ant], 0 )"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "285b260d-346b-4933-ac81-5d75294ec951"
          },
          {
            "name": "01. Media de Faturamento",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "// calcula a media de faturtamento no mes selecionado",
              "VAR vTABELA = ",
              "AVERAGEX(",
              "    VALUES( 'CALENDARIO DAX'[Dia] ),",
              "    [01. Total Faturamento] )",
              "",
              "RETURN",
              "vTABELA"
            ],
            "lineageTag": "f590004f-c101-4a63-b823-efce8fd030ca"
          },
          {
            "name": "HTML_Filtros_Ativos",
            "expression": [
              "",
              "// Mostra o Botão com Filtros Aplicados",
              "",
              "VAR MinData = MIN('CALENDARIO DAX'[Date])",
              "VAR MaxData = MAX('CALENDARIO DAX'[Date])",
              "",
              "-- Valores selecionados (texto) por filtro",
              "VAR Filtro1  = IF(ISFILTERED('CALENDARIO DAX'[Date]), FORMAT(MinData, \"dd mmm yyyy\") & \" a \" & FORMAT(MaxData, \"dd mmm yyyy\"), BLANK())",
              "VAR Filtro2  = IF(ISFILTERED(TB_Empresa[EMP_NomeFantasia]), CONCATENATEX(VALUES(TB_Empresa[EMP_NomeFantasia]), TB_Empresa[EMP_NomeFantasia], \", \"), BLANK())",
              "VAR Filtro3  = IF(ISFILTERED(TB_GProduto[GRP_Descricao]), CONCATENATEX(VALUES(TB_GProduto[GRP_Descricao]), TB_GProduto[GRP_Descricao], \", \"), BLANK())",
              "VAR Filtro4  = IF(ISFILTERED(TB_Produto[PRD_Descricao]), CONCATENATEX(VALUES(TB_Produto[PRD_Descricao]), TB_Produto[PRD_Descricao], \", \"), BLANK())",
              "",
              "-- Contagem de filtros ativos",
              "VAR TotalFiltros =",
              "    (NOT ISBLANK(Filtro1)) + (NOT ISBLANK(Filtro2)) + (NOT ISBLANK(Filtro3)) +",
              "    (NOT ISBLANK(Filtro4)) ",
              "",
              "VAR Texto =",
              "    IF(TotalFiltros = 1, \"1 ativo\", FORMAT(TotalFiltros, \"0\") & \" ativos\")",
              "",
              "-- Tooltip (caixa) com títulos em negrito",
              "VAR TooltipHTML =",
              "    \"<div style='background:#fff;",
              "            border:1px solid #118DFF;",
              "            border-radius:10px;",
              "            padding:12px 16px;",
              "            font-size:12px;",
              "            color:#333;",
              "            line-height:18px;",
              "            box-shadow:0 2px 6px rgba(0,0,0,0.2);",
              "            width: 1000px;",
              "            max-width:800px;",
              "            max-height:250px;",
              "            overflow-y:auto;'>",
              "        <div style='font-weight:bold; margin-bottom:4px;'>Filtros Aplicados:</div>\" &",
              "        IF(NOT ISBLANK(Filtro1),  \"<div><b>Data:</b> \" & Filtro1 & \"</div>\", \"\") &",
              "        IF(NOT ISBLANK(Filtro2),  \"<div><b>Tipo:</b> \" & Filtro2 & \"</div>\", \"\") &",
              "        IF(NOT ISBLANK(Filtro3),  \"<div><b>Empresa:</b> \" & Filtro3 & \"</div>\", \"\") &",
              "        IF(NOT ISBLANK(Filtro4),  \"<div><b>Grupo Produtos:</b> \" & Filtro4 & \"</div>\", \"\") &",
              "    \"</div>\"",
              "",
              "RETURN",
              "IF(",
              "    TotalFiltros > 0,",
              "    \"<details style='display:inline-block; position:relative;'>",
              "        <summary style='list-style:none; outline:none; cursor:pointer;'>",
              "            <span style='background-color: rgba(17,141,255,0.1);",
              "                         color:#118DFF;",
              "                         border:1px solid #118DFF;",
              "                         border-radius:15px;",
              "                         padding:3px 10px;",
              "                         font-size:8px;",
              "                         font-weight:bold;",
              "                         display:inline-block;'>\" & Texto & \"</span>",
              "        </summary>",
              "    </details>\",",
              "    \"\"",
              ")",
              ""
            ],
            "lineageTag": "c8aedbf4-ca0b-4255-a1cf-c29f6197e94c"
          }
        ],
        "partitions": [
          {
            "name": "_Medidas",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Fonte = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText(\"i44FAA==\", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [#\"Coluna 1\" = _t]),",
                "    #\"Tipo Alterado\" = Table.TransformColumnTypes(Fonte,{{\"Coluna 1\", type text}}),",
                "    #\"Colunas Removidas\" = Table.RemoveColumns(#\"Tipo Alterado\",{\"Coluna 1\"})",
                "in",
                "    #\"Colunas Removidas\""
              ],
              "type": "m"
            }
          }
        ]
      },
