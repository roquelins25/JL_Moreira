        "lineageTag": "c1129b92-d7c3-44cf-ad21-17626ffd5317",
        "measures": [
          {
            "name": "TOTAL_DIAS",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT('CALENDARIO DAX'[Date]),",
              "    'Calendario DAX'[Mês] = MONTH(SELECTEDVALUE('Atualização'[data atualizada])) &&",
              "    'Calendario DAX'[Ano] = YEAR(SELECTEDVALUE('Atualização'[data atualizada]))",
              "    )"
            ],
            "lineageTag": "da5ce4fa-8846-40bb-9144-017ddce24f5a"
          },
          {
            "name": "DIAS_PERCORRIDOS",
            "expression": [
              "",
              "CALCULATE(",
              "    [TOTAL_DIAS],",
              "    'CALENDARIO DAX'[Date] <= SELECTEDVALUE('Atualização'[data atualizada])",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "c7a40e26-f7ad-4529-b9d4-6210dbc5f9b3"
          },
          {
            "name": "Dias Faltantes",
            "expression": [
              "",
              "VAR vDIAS =",
              "[TOTAL_DIAS] - [DIAS_PERCORRIDOS]",
              "RETURN",
              "\"Faltam: \" & FORMAT( vDIAS, \"\" ) & \" Dias Úteis\""
            ],
            "lineageTag": "9e91b074-c3aa-4bef-9c8c-41fa7b1c1913"
          }
        ],
        "partitions": [
          {
            "name": "CALENDARIO DAX",
            "mode": "import",
            "source": {
              "expression": [
                "",
                "var minAno = YEAR(MIN(TB_NotaFiscal[NTF_DataEmissao])) //2021",
                "var MaxAno = YEAR(MAX(TB_NotaFiscal[NTF_DataEmissao])) //2026",
                "RETURN",
                "ADDCOLUMNS(",
                "    FILTER(",
                "        CALENDARAUTO(),",
                "        YEAR([Date]) >= minAno &&",
                "        YEAR([Date]) <= MaxAno),",
                "        \"Ano\", YEAR([Date]),",
                "        \"AnoNumber\", YEAR( [Date] ),",
                "        \"Mês\", MONTH([Date]),",
                "        \"Nome do Mês\", FORMAT([Date],\"mmmm\",\"PT-BR\"),",
                "        \"Mês Abrev\",UPPER(LEFT(FORMAT([Date], \"mmm\"), 1)) & LOWER(RIGHT(FORMAT([Date], \"mmm\"), 2)),",
                "        \"trimestre\", CONCATENATE(QUARTER([Date]),\"-Trimestre\"),",
                "        \"semestre\", SWITCH(",
                "                        TRUE(),",
                "                        MONTH([Date]) IN{1,2,3,4,5,6}, \"1-Sem\",",
                "                        \"2-Sem\"),",
                "        \"Dia\",DAY([Date]),",
                "        \"Dia/Mes\", FORMAT([Date],\"dd-mmm\") ,",
                "        \"SemanaDIAnum\", WEEKDAY( [Date], 1 ),",
                "        \"DiasSemana\",SWITCH(",
                "            WEEKDAY([Date]),",
                "            1,\"Domingo\",",
                "            2,\"Segunda\",",
                "            3,\"Terça\",",
                "            4,\"Quarta\",",
                "            5,\"Quinta\",",
                "            6,\"Sexta\",",
                "            7,\"Sabado\"),",
                "        \"SemanaDiaNome\", FORMAT( [Date] , \"ddd\"),",
                "        \"Mes Atual\", IF( YEAR( [Date] ) = YEAR( TODAY() ) && MONTH( [Date] ) = MONTH( TODAY() ), \"S\", \"N\" ),",
                "        \"Ano Atual\", IF( YEAR( [Date] ) = YEAR( TODAY() ) , \"S\", \"N\" ),",
                "        \"Ano-Mes\", UPPER(LEFT(FORMAT([Date], \"mmm\"), 1)) & LOWER(RIGHT(FORMAT([Date], \"mmm\"), 2)) & \"-\" & YEAR( [Date] ),",
                "        \"OrderBy\", (YEAR( [Date] )*100) + MONTH( [Date] ),",
                "        \"Numerosemana\", WEEKNUM( [Date])",
                "    )"
              ],
              "type": "calculated"
            }
          }
        ]
      },
