              "    TRUE(),",
              "    HASONEFILTER( _Senhas[acesso] ) && xSenha[Valor xSenha] = MAX( _Senhas[Senha] ), \"HOME\", ",
              "    \"Senha Incorreta\" )"
            ],
            "lineageTag": "ff822c70-4070-4660-8f6c-fce412a32d18"
          }
