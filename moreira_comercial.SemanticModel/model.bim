        "lineageTag": "7e40f7f1-75f4-49a1-93a5-bc77d3db3b55",
        "partitions": [
          {
            "name": "TB_Cliente",
            "mode": "import",
            "queryGroup": "TB_Dimensao",
            "source": {
              "expression": [
                "let",
                "    Fonte = PowerPlatform.Dataflows(null),",
                "    Workspaces = Fonte{[Id=\"Workspaces\"]}[Data],",
                "    #\"6b3d0be9-cdbd-4454-b8dc-62bf05ebb307\" = Workspaces{[workspaceId=\"6b3d0be9-cdbd-4454-b8dc-62bf05ebb307\"]}[Data],",
